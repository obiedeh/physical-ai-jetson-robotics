<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="rosmaster_m3pro_arm_6dof"
    params="parent origin_xyz origin_rpy
            shoulder_height upper_arm_length forearm_length
            wrist_length tool_length">

    <!-- Arm visuals are provided by chassis.stl (full-body CAD mesh on base_link).
         Only collision geometry is defined here so the kinematic chain stays valid. -->

    <link name="arm_base_link">
      <collision>
        <origin rpy="0 0 0" xyz="0 0 ${shoulder_height/2}"/>
        <geometry><cylinder length="${shoulder_height}" radius="0.055"/></geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="0 0 ${shoulder_height/2}"/>
        <mass value="0.7"/>
        <inertia ixx="0.001001875" ixy="0" ixz="0" iyy="0.001001875" iyz="0" izz="0.00105875"/>
      </inertial>
    </link>

    <joint name="arm_mount_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="arm_base_link"/>
      <origin rpy="${origin_rpy}" xyz="${origin_xyz}"/>
    </joint>

    <link name="shoulder_link">
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry><box size="0.095 0.095 0.090"/></geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="0 0 0.020"/>
        <mass value="0.45"/>
        <inertia ixx="0.000642" ixy="0" ixz="0" iyy="0.000642" iyz="0" izz="0.000677"/>
      </inertial>
    </link>

    <joint name="joint_1" type="revolute">
      <parent link="arm_base_link"/>
      <child link="shoulder_link"/>
      <origin rpy="0 0 0" xyz="0 0 ${shoulder_height}"/>
      <axis xyz="0 0 1"/>
      <limit effort="30.0" lower="-3.14159" upper="3.14159" velocity="1.5"/>
    </joint>

    <link name="upper_arm_link">
      <collision>
        <origin rpy="0 0 0" xyz="${upper_arm_length/2} 0 0"/>
        <geometry><box size="${upper_arm_length} 0.060 0.070"/></geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${upper_arm_length/2} 0 0"/>
        <mass value="0.55"/>
        <inertia ixx="0.000390" ixy="0" ixz="0" iyy="0.002246" iyz="0" izz="0.002186"/>
      </inertial>
    </link>

    <joint name="joint_2" type="revolute">
      <parent link="shoulder_link"/>
      <child link="upper_arm_link"/>
      <origin rpy="0 0 0" xyz="0 0 0.040"/>
      <axis xyz="0 1 0"/>
      <limit effort="30.0" lower="-1.5708" upper="1.5708" velocity="1.5"/>
    </joint>

    <link name="forearm_link">
      <collision>
        <origin rpy="0 0 0" xyz="${forearm_length/2} 0 0"/>
        <geometry><box size="${forearm_length} 0.055 0.060"/></geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${forearm_length/2} 0 0"/>
        <mass value="0.45"/>
        <inertia ixx="0.000248" ixy="0" ixz="0" iyy="0.001489" iyz="0" izz="0.001467"/>
      </inertial>
    </link>

    <joint name="joint_3" type="revolute">
      <parent link="upper_arm_link"/>
      <child link="forearm_link"/>
      <origin rpy="0 0 0" xyz="${upper_arm_length} 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="25.0" lower="-2.3562" upper="2.3562" velocity="1.5"/>
    </joint>

    <link name="wrist_1_link">
      <collision>
        <origin rpy="0 0 0" xyz="0 0 ${wrist_length/2}"/>
        <geometry><cylinder length="${wrist_length}" radius="0.032"/></geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="0 0 ${wrist_length/2}"/>
        <mass value="0.2"/>
        <inertia ixx="0.000172" ixy="0" ixz="0" iyy="0.000172" iyz="0" izz="0.000102"/>
      </inertial>
    </link>

    <joint name="joint_4" type="revolute">
      <parent link="forearm_link"/>
      <child link="wrist_1_link"/>
      <origin rpy="0 0 0" xyz="${forearm_length} 0 0"/>
      <axis xyz="1 0 0"/>
      <limit effort="15.0" lower="-3.14159" upper="3.14159" velocity="2.0"/>
    </joint>

    <link name="wrist_2_link">
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry><box size="0.055 0.070 0.055"/></geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <mass value="0.18"/>
        <inertia ixx="0.000119" ixy="0" ixz="0" iyy="0.000091" iyz="0" izz="0.000119"/>
      </inertial>
    </link>

    <joint name="joint_5" type="revolute">
      <parent link="wrist_1_link"/>
      <child link="wrist_2_link"/>
      <origin rpy="0 0 0" xyz="0 0 ${wrist_length}"/>
      <axis xyz="0 1 0"/>
      <limit effort="15.0" lower="-1.5708" upper="1.5708" velocity="2.0"/>
    </joint>

    <link name="tool0">
      <collision>
        <origin rpy="0 0 0" xyz="${tool_length/2} 0 0"/>
        <geometry><box size="${tool_length} 0.045 0.045"/></geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${tool_length/2} 0 0"/>
        <mass value="0.12"/>
        <inertia ixx="0.000040" ixy="0" ixz="0" iyy="0.000101" iyz="0" izz="0.000101"/>
      </inertial>
    </link>

    <joint name="joint_6" type="revolute">
      <parent link="wrist_2_link"/>
      <child link="tool0"/>
      <origin rpy="0 0 0" xyz="0 0 0.070"/>
      <axis xyz="1 0 0"/>
      <limit effort="10.0" lower="-3.14159" upper="3.14159" velocity="2.5"/>
    </joint>

  </xacro:macro>
</robot>
