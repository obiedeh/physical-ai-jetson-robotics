# Environment variables for physical-ai-jetson-robotics
# Copy to .env and fill in values. Never commit .env.

# ROS 2 domain isolation (0-232). Must match across all nodes in the same session.
ROS_DOMAIN_ID=42

# Compute target: workstation | jetson-orin | jetson-thor
PHYSICAL_AI_COMPUTE_TARGET=workstation

# Path to model weights for edge inference benchmarks
# PHYSICAL_AI_MODELS_DIR=/models

# Optional: OpenAI-compatible endpoint for future VLM/LLM ops copilot integration
# OPENAI_API_BASE=http://localhost:8000/v1
# OPENAI_API_KEY=

# Optional: Suppress CUDA device visibility for CPU-only runs
# CUDA_VISIBLE_DEVICES=
